---
// DemosSection — renders all non-draft demos as a 2-column grid with
// live inline iframe embeds. Used on both /demos (as the whole page) and
// the home page (inserted between Case Studies and Testimonials).
//
// Props:
//   compact:   boolean  — tighter top/bottom padding, omits toc & page CTA.
//                         Use on home page.
//   showHeader:boolean  — if false, caller renders its own heading. Default true.
//
import DemoEmbed from './DemoEmbed.astro';
import ArrowTrack from './ArrowTrack.astro';
import { getCollection } from 'astro:content';

export interface Props {
  compact?: boolean;
  showHeader?: boolean;
}

const { compact = false, showHeader = true } = Astro.props;

const all = await getCollection('demos', ({ data }) => !data.draft);
const sorted = all.sort((a, b) => a.data.order - b.data.order);
---

<section class:list={['demos-section', compact && 'demos-section--compact']}>
  <div class="demos-section__inner">

    {showHeader && !compact && (
      <header class="demos-section__header">
        <div class="eyebrow">Live Demos</div>
        <h2 class="demos-section__title">Every demo below is a real system. <em>Use them all right here.</em></h2>
        <p class="demos-section__lede">
          No signup, no download, no sales call. Each tool is fully interactive — poke at them, try the inputs, see what fits your business.
        </p>
      </header>
    )}

    {showHeader && compact && (
      <header class="demos-section__header demos-section__header--compact">
        <div class="eyebrow">Live Demos</div>
        <h2 class="demos-section__title">See it before you sign anything.</h2>
        <p class="demos-section__lede">
          Every tool below is working software running right here on this page. No signup, no demo call, no download.
        </p>
      </header>
    )}

    <div class="demos-section__grid">
      {sorted.map((d) => {
        const isLive = Boolean(d.data.liveUrl && d.data.liveUrl.length > 0);
        return (
          <article id={`demo-${d.slug}`} class="demo-cell">
            <div class="demo-cell__head">
              <div class="demo-cell__tags">
                {d.data.tags.map((t) => <span class="demo-cell__tag">{t}</span>)}
              </div>
              <h3 class="demo-cell__title">{d.data.title}</h3>
              <p class="demo-cell__pitch">{d.data.pitch}</p>
              <div class="demo-cell__meta">
                {d.data.timeline && <span>{d.data.timeline}</span>}
                {d.data.timeline && <span class="demo-cell__meta-sep">·</span>}
                <a href={`/demos/${d.slug}`} class="demo-cell__details-link">Full details<ArrowTrack /></a>
              </div>
            </div>
            <div class="demo-cell__embed">
              <!-- Desktop / tablet: uniform browser-window chrome wrapping every demo -->
              <div class="demo-window">
                <div class="demo-window__chrome">
                  <span class="demo-window__dot"></span>
                  <span class="demo-window__dot"></span>
                  <span class="demo-window__dot"></span>
                  <span class="demo-window__url">
                    {isLive
                      ? (d.data.liveUrl ?? '').replace(/^https?:\/\//, '').replace(/\/$/, '').slice(0, 48)
                      : 'coming-soon.crescendo-consulting.net'}
                  </span>
                  {isLive && (
                    <div class="demo-window__actions">
                      <button class="demo-window__btn" data-action="copy" data-url={d.data.liveUrl} aria-label="Copy demo URL" title="Copy URL">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                      </button>
                      <button class="demo-window__btn" data-action="fullscreen" aria-label="Toggle fullscreen" title="Fullscreen">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8V3h5M21 8V3h-5M3 16v5h5M21 16v5h-5"/></svg>
                      </button>
                      <a class="demo-window__btn" href={d.data.liveUrl} target="_blank" rel="noopener noreferrer" aria-label="Open demo in new tab" title="Open in new tab">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                      </a>
                    </div>
                  )}
                </div>
                <div class="demo-window__body">
                  {isLive ? (
                    <DemoEmbed
                      src={d.data.liveUrl}
                      title={`Crescendo — ${d.data.title} demo`}
                      caption="Live interactive demo · sample data only"
                      aspect={d.data.aspect}
                      sandbox={d.data.sandbox}
                      allow={d.data.allow}
                      resizeSource={d.data.resizeSource}
                      initialHeight={d.data.initialHeight}
                      fluid={true}
                    />
                  ) : (
                    <div class="demo-cell__coming-soon">
                      <div class="demo-cell__coming-soon-icon">⧖</div>
                      <div class="demo-cell__coming-soon-title">Coming soon</div>
                      <div class="demo-cell__coming-soon-dek">
                        <a data-cal-link="gavin-coleman-pxrlkg/intro" data-cal-namespace="intro" data-cal-config='{"layout":"week_view","useSlotsViewOnSmallScreen":"true"}' style="cursor:pointer;color:#fff;text-decoration:underline;">Book a call</a> for early access.
                      </div>
                    </div>
                  )}
                </div>
              </div>

              <!-- Mobile-only fallback: dashboards are unreadable on phones, so show a tappable card instead of an unreadable iframe -->
              {isLive && (
                <a class="demo-cell__mobile-cta" href={d.data.liveUrl} target="_blank" rel="noopener noreferrer">
                  <div class="demo-cell__mobile-cta-body">
                    <div class="demo-cell__mobile-cta-title">{d.data.title}</div>
                    <div class="demo-cell__mobile-cta-dek">Built for desktop dashboards. Tap to open the live demo in a new tab — or come back on a laptop for the full experience.</div>
                  </div>
                  <div class="demo-cell__mobile-cta-action">
                    Open demo
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
                  </div>
                </a>
              )}
            </div>
          </article>
        );
      })}
    </div>

    {compact && (
      <div class="demos-section__footer-cta">
        <a href="/demos" class="btn btn--primary">See all demos full-screen →</a>
      </div>
    )}

  </div>
</section>

<script>
  // Toast helper — single shared element for the whole page
  let toastEl: HTMLDivElement | null = null;
  let toastTimer: number | null = null;
  function showToast(msg: string) {
    if (!toastEl) {
      toastEl = document.createElement('div');
      toastEl.className = 'crescendo-toast';
      document.body.appendChild(toastEl);
    }
    toastEl.textContent = msg;
    toastEl.classList.add('is-visible');
    if (toastTimer) window.clearTimeout(toastTimer);
    toastTimer = window.setTimeout(() => {
      toastEl?.classList.remove('is-visible');
    }, 1800);
  }

  // Copy URL buttons
  document.querySelectorAll<HTMLButtonElement>('.demo-window__btn[data-action="copy"]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = btn.dataset.url;
      if (!url) return;
      try {
        await navigator.clipboard.writeText(url);
        showToast('Demo URL copied');
      } catch {
        showToast('Could not copy — open the URL manually');
      }
    });
  });

  // Fullscreen toggle on the demo-window
  document.querySelectorAll<HTMLButtonElement>('.demo-window__btn[data-action="fullscreen"]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const win = btn.closest('.demo-window') as HTMLElement | null;
      if (!win) return;
      if (document.fullscreenElement) {
        document.exitFullscreen();
      } else if (win.requestFullscreen) {
        win.requestFullscreen();
      }
    });
  });
</script>

<style>
  .demos-section {
    background: #fafaf7;
    padding: 120px 24px;
  }
  .demos-section--compact {
    padding: 96px 24px;
  }
  .demos-section__inner {
    max-width: 1480px;
    margin: 0 auto;
  }

  .demos-section__header {
    max-width: 760px;
    margin: 0 auto 72px;
    text-align: center;
  }
  .demos-section__header--compact {
    margin-bottom: 56px;
  }
  .demos-section__title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(34px, 4.5vw, 48px);
    font-weight: 500;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: #0a0e27;
    margin: 16px 0 20px;
  }
  .demos-section__title em {
    font-style: italic;
    font-weight: 400;
  }
  .demos-section__lede {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 19px;
    line-height: 1.55;
    color: #3a3f54;
    margin: 0;
  }

  /* GRID — 2 columns desktop, 1 column mobile */
  .demos-section__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 80px 48px;
  }
  @media (max-width: 960px) {
    .demos-section__grid {
      grid-template-columns: 1fr;
      gap: 64px;
    }
  }

  /* DEMO CELL */
  .demo-cell {
    display: flex;
    flex-direction: column;
    gap: 24px;
    scroll-margin-top: 80px;
  }
  .demo-cell__head {
    text-align: center;
  }
  .demo-cell__tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 12px;
  }
  .demo-cell__tag {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #6b7280;
    background: #f0ede4;
    padding: 4px 10px;
    border-radius: 4px;
  }
  .demo-cell__title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(24px, 2.5vw, 30px);
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.012em;
    color: #0a0e27;
    margin: 4px 0 10px;
  }
  .demo-cell__pitch {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 17px;
    line-height: 1.5;
    color: #3a3f54;
    margin: 0 0 14px;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }
  .demo-cell__meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: #6b7280;
  }
  .demo-cell__meta strong {
    color: #0a0e27;
    font-weight: 600;
  }
  .demo-cell__meta-sep {
    color: #c7c4b8;
  }
  .demo-cell__details-link {
    color: #9921F2;
    text-decoration: none;
    font-weight: 600;
  }
  .demo-cell__details-link:hover {
    text-decoration: underline;
  }

  /* EMBED CELL — uniform 560px height across all demos.
     Now contains a browser-window chrome that wraps every embed for visual parity. */
  .demo-cell__embed {
    width: 100%;
    height: 560px;
    display: block;
  }

  /* DEMO WINDOW — the consistent navy chrome around every iframe */
  .demo-window {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    background: #0a0e27;
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 1px 2px rgba(10, 14, 39, 0.08),
      0 24px 48px -24px rgba(10, 14, 39, 0.35);
    border: 1px solid rgba(10, 14, 39, 0.12);
  }
  .demo-window__chrome {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 16px;
    background: #141835;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .demo-window__dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    flex-shrink: 0;
  }
  .demo-window__dot:nth-child(1) { background: #ff5f57; }
  .demo-window__dot:nth-child(2) { background: #febc2e; }
  .demo-window__dot:nth-child(3) { background: #28c840; }
  .demo-window__url {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, monospace;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: -0.01em;
    margin-left: 8px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
  }
  /* Action buttons in the chrome — Copy / Fullscreen / Open */
  .demo-window__actions {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
  }
  .demo-window__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    padding: 0;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    color: rgba(255, 255, 255, 0.55);
    cursor: pointer;
    transition: all 0.15s ease;
    text-decoration: none;
  }
  .demo-window__btn:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.18);
    color: rgba(255, 255, 255, 0.95);
  }
  .demo-window__btn:active {
    transform: scale(0.96);
  }
  .demo-window__body {
    flex: 1 1 auto;
    position: relative;
    overflow: hidden;
    background: #fff;
    min-height: 0;
  }

  /* Force DemoEmbed to fill the body of the window chrome exactly */
  .demo-window__body :global(.crescendo-demo) {
    width: 100%;
    height: 100%;
    max-width: 100% !important;
    margin: 0 !important;
    display: flex;
    flex-direction: column;
  }
  .demo-window__body :global(.crescendo-demo__frame) {
    flex: 1 1 auto;
    height: 100% !important;
    min-height: 0 !important;
    aspect-ratio: auto !important;
    border-radius: 0 !important;
    border: none !important;
    box-shadow: none !important;
    background: #fff !important;
  }
  /* Hide DemoEmbed's own figcaption — redundant with the window chrome */
  .demo-window__body :global(.crescendo-demo figcaption) {
    display: none;
  }

  /* Scale-to-fit trick: render each iframe at a full desktop viewport, then
     scale it down visually to fit the cell. Apps get the layout they were
     designed for instead of a cramped ~700px viewport. */
  .demo-window__body :global(.crescendo-demo--landscape iframe),
  .demo-window__body :global(.crescendo-demo--auto iframe) {
    width: 167% !important;
    height: 167% !important;
    transform: scale(0.6);
    transform-origin: top left;
  }

  /* Portrait demo inside window: center with a matching navy letterbox.
     Portrait apps are designed for phone viewports, so we render at a
     slightly larger phone width and scale down subtly. */
  .demo-window__body :global(.crescendo-demo--portrait) {
    max-width: 360px !important;
    margin: 0 auto !important;
    background: transparent;
  }
  .demo-window__body :global(.crescendo-demo--portrait iframe) {
    width: 125% !important;
    height: 125% !important;
    transform: scale(0.8);
    transform-origin: top left;
  }
  /* When portrait is letterboxed, paint the surrounding area navy to match the window */
  .demo-window:has(:global(.crescendo-demo--portrait)) .demo-window__body {
    background: #0a0e27;
  }

  @media (max-width: 960px) {
    .demo-cell__embed { height: 520px; }
  }
  @media (max-width: 760px) {
    /* Below 760px, dashboards are unreadable. Hide the demo-window entirely
       and show the tappable mobile CTA card instead. */
    .demo-cell__embed { height: auto; }
    .demo-cell__embed .demo-window { display: none; }
    .demo-cell__mobile-cta { display: flex; }
  }
  @media (max-width: 600px) {
    .demo-window__body :global(.crescendo-demo--portrait) { max-width: 100% !important; }
  }

  /* Mobile fallback CTA — tappable card replacing the iframe on small screens */
  .demo-cell__mobile-cta {
    display: none; /* shown only on mobile via media query above */
    flex-direction: column;
    gap: 18px;
    background: linear-gradient(135deg, #0a0e27 0%, #141835 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    padding: 24px 22px;
    text-decoration: none;
    color: #fff;
    box-shadow:
      0 1px 2px rgba(10, 14, 39, 0.08),
      0 24px 48px -24px rgba(10, 14, 39, 0.35);
    transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .demo-cell__mobile-cta:active {
    transform: scale(0.99);
    border-color: rgba(59, 130, 246, 0.4);
  }
  .demo-cell__mobile-cta-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: #fff;
    margin-bottom: 8px;
  }
  .demo-cell__mobile-cta-dek {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    line-height: 1.5;
    color: #b8c1d6;
  }
  .demo-cell__mobile-cta-action {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 18px;
    background: #3b82f6;
    color: #fff;
    border-radius: 10px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    align-self: flex-start;
  }

  /* Fullscreen mode — when a demo-window is fullscreened, blow it out */
  .demo-window:fullscreen,
  .demo-window:-webkit-full-screen {
    width: 100vw;
    height: 100vh;
    border-radius: 0;
    border: none;
  }
  .demo-window:fullscreen .demo-window__body,
  .demo-window:-webkit-full-screen .demo-window__body {
    height: calc(100vh - 46px);
  }

  /* COMING SOON — fills the window body, matches chrome aesthetic */
  .demo-cell__coming-soon {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #0a0e27 0%, #9921F2 100%);
    color: #fff;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 32px;
    text-align: center;
  }
  .demo-cell__coming-soon-icon {
    font-size: 36px;
    opacity: 0.7;
  }
  .demo-cell__coming-soon-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 22px;
    font-weight: 500;
  }
  .demo-cell__coming-soon-dek {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: rgba(255,255,255,0.85);
  }

  /* Compact variant footer CTA */
  .demos-section__footer-cta {
    margin-top: 56px;
    text-align: center;
  }

  @media (max-width: 600px) {
    .demos-section { padding: 80px 20px; }
    .demos-section--compact { padding: 72px 20px; }
  }
</style>

<!-- Toast notification — global, single instance, used by Copy URL action.
     Defined as global styles so the JS-injected element picks them up. -->
<style is:global>
  .crescendo-toast {
    position: fixed;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%) translateY(80px);
    background: #141835;
    color: #ffffff;
    padding: 12px 20px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.01em;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35);
    transition: transform 0.25s ease, opacity 0.25s ease;
    opacity: 0;
    pointer-events: none;
    z-index: 99999;
  }
  .crescendo-toast.is-visible {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }
</style>
