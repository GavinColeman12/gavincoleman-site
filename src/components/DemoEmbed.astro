---
// Reusable demo embed, drop into any .astro page or .mdx content file.
//
// Three aspect variants:
//
//   landscape (default): 16:10 dashboard style, max 1200px
//     <DemoEmbed src="..." />
//
//   portrait: 9:16 phone-app style, max 560px
//     <DemoEmbed src="..." aspect="portrait" />
//
//   auto: content-driven, auto-resizes via postMessage from iframe
//     <DemoEmbed src="..." aspect="auto" resizeSource="geo-visibility-checker" />
//
// With sandbox flags (stricter iframe permissions):
//   <DemoEmbed src="..." sandbox="allow-scripts allow-same-origin allow-forms allow-popups" />
export interface Props {
  src: string;
  title?: string;
  caption?: string;
  newTabLabel?: string;
  aspect?: 'landscape' | 'portrait' | 'auto';
  sandbox?: string;
  allow?: string;
  resizeSource?: string;
  initialHeight?: number;
  fluid?: boolean; // when true, removes max-width so the embed fills its container
}

const {
  src,
  title = 'Interactive demo',
  caption = 'Live interactive demo · sample data only',
  newTabLabel = 'Open in new tab ↗',
  aspect = 'landscape',
  sandbox,
  allow = 'clipboard-read; clipboard-write; fullscreen',
  resizeSource,
  initialHeight = 900,
  fluid = false,
} = Astro.props;

const wrapClass = `crescendo-demo crescendo-demo--${aspect}${fluid ? ' crescendo-demo--fluid' : ''}`;
// Unique id for auto-resize variant so the listener targets the right frame
// Skip auto-resize entirely in fluid mode, the container height is fixed by the grid.
const shouldAutoResize = aspect === 'auto' && !fluid;
const frameId = shouldAutoResize ? `cc-demo-${Math.random().toString(36).slice(2, 9)}` : undefined;
---

<figure class={wrapClass}>
  <div class="crescendo-demo__frame" style={aspect === 'auto' ? `height:${initialHeight}px;` : ''}>
    <!-- Loading skeleton, shown until iframe fires its load event. Sits behind the iframe (z-index 1, iframe is on top with opacity 0 → 1). -->
    <div class="crescendo-demo__skeleton" aria-hidden="true">
      <div class="crescendo-demo__pulse"></div>
      <div class="crescendo-demo__skeleton-label">Waking the demo…</div>
      <div class="crescendo-demo__skeleton-sub">First load can take 10–20 seconds.</div>
    </div>
    <iframe
      id={frameId}
      data-src={src}
      title={title}
      loading="lazy"
      allow={allow}
      sandbox={sandbox}
    ></iframe>
  </div>
  <figcaption>
    <span>{caption}</span>
    <a href={src} target="_blank" rel="noopener noreferrer">{newTabLabel}</a>
  </figcaption>
</figure>

<script>
  // IntersectionObserver-based lazy load with a real loading skeleton.
  // Browser-native loading="lazy" doesn't give us the "skeleton until load
  // event" UX, and it eagerly fetches earlier than we want for cold-starting
  // services (Railway free tier sleeps after inactivity).
  function setupCrescendoDemo(frame: Element) {
    const iframe = frame.querySelector('iframe[data-src]') as HTMLIFrameElement | null;
    if (!iframe) return;
    const src = iframe.getAttribute('data-src');
    if (!src) return;

    let loaded = false;
    function load() {
      if (loaded) return;
      loaded = true;
      iframe!.addEventListener(
        'load',
        () => {
          frame.classList.add('is-loaded');
        },
        { once: true }
      );
      // Fallback, if the iframe never fires load (cross-origin error, blocked,
      // network hung), reveal it after 25s anyway so users aren't staring at
      // a spinner forever.
      setTimeout(() => frame.classList.add('is-loaded'), 25000);
      iframe!.src = src!;
    }

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              load();
              io.disconnect();
            }
          });
        },
        { rootMargin: '300px' }
      );
      io.observe(frame);
    } else {
      load();
    }
  }

  // One global wire-up per page load, handles every demo embed at once
  document.querySelectorAll('.crescendo-demo__frame').forEach(setupCrescendoDemo);
</script>

{shouldAutoResize && resizeSource && (
  <script is:inline define:vars={{ frameId, resizeSource }}>
    (function () {
      var frame = document.getElementById(frameId);
      if (!frame) return;
      window.addEventListener('message', function (e) {
        if (!e.data || e.data.source !== resizeSource) return;
        if (e.data.type === 'resize' && typeof e.data.height === 'number') {
          var wrap = frame.parentElement;
          if (wrap) wrap.style.height = (e.data.height + 8) + 'px';
        }
      });
    })();
  </script>
)}

<style>
  .crescendo-demo {
    margin: 0 auto;
  }
  /* Non-fluid default: centered with vertical margin */
  .crescendo-demo:not(.crescendo-demo--fluid) {
    margin: 2.5rem auto;
  }
  /* Fluid: fills container width, no max-width, tighter margin */
  .crescendo-demo--fluid {
    max-width: 100%;
    width: 100%;
    margin: 0 auto;
  }

  /* Landscape, dashboard-style, wide */
  .crescendo-demo--landscape {
    max-width: 1200px;
  }
  .crescendo-demo--landscape.crescendo-demo--fluid {
    max-width: 100%;
  }
  .crescendo-demo--landscape .crescendo-demo__frame {
    aspect-ratio: 16 / 10;
  }
  @media (max-width: 640px) {
    .crescendo-demo--landscape .crescendo-demo__frame {
      aspect-ratio: 3 / 4;
    }
  }

  /* Portrait, phone-shaped app */
  .crescendo-demo--portrait {
    max-width: 640px;
  }
  .crescendo-demo--portrait .crescendo-demo__frame {
    aspect-ratio: 9 / 16;
    min-height: 720px;
  }
  @media (min-width: 768px) {
    .crescendo-demo--portrait {
      max-width: 560px;
    }
    .crescendo-demo--portrait .crescendo-demo__frame {
      min-height: 820px;
    }
  }
  /* Fluid portrait: when embedded in a grid cell, don't exceed the column
     width but still preserve phone-like proportions. Cap max height so the
     phone doesn't overwhelm the grid row. */
  .crescendo-demo--portrait.crescendo-demo--fluid {
    max-width: 420px;
  }
  .crescendo-demo--portrait.crescendo-demo--fluid .crescendo-demo__frame {
    min-height: 680px;
  }

  /* Auto, content-driven height via postMessage */
  .crescendo-demo--auto {
    max-width: 900px;
  }
  .crescendo-demo--auto.crescendo-demo--fluid {
    max-width: 100%;
  }
  .crescendo-demo--auto .crescendo-demo__frame {
    /* height set inline from initialHeight; resizes via postMessage listener */
    transition: height 0.2s ease;
  }

  /* Shared frame styling, unified across all aspect variants.
     Light warm background matches the site's off-white aesthetic and avoids
     weird dark letterbox around the phone-shaped portrait intake form. */
  .crescendo-demo__frame {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: #f8fafc;
    box-shadow:
      0 1px 2px rgba(10, 14, 39, 0.06),
      0 20px 40px -20px rgba(10, 14, 39, 0.20);
    border: 1px solid rgba(10, 14, 39, 0.08);
  }
  .crescendo-demo__frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    opacity: 0;
    transition: opacity 0.45s ease;
    z-index: 2;
  }
  .crescendo-demo__frame.is-loaded iframe { opacity: 1; }

  /* Loading skeleton, visible until the iframe load event fires.
     Sits underneath the iframe; iframe fades in over it. */
  .crescendo-demo__skeleton {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 14px;
    padding: 24px;
    background: linear-gradient(135deg, #0a0e27 0%, #141835 100%);
    color: #b8c1d6;
    font-family: 'Inter', sans-serif;
    text-align: center;
    transition: opacity 0.45s ease;
    pointer-events: none;
  }
  .crescendo-demo__frame.is-loaded .crescendo-demo__skeleton {
    opacity: 0;
  }
  .crescendo-demo__pulse {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 2px solid rgba(59, 130, 246, 0.18);
    border-top-color: #3b82f6;
    animation: crescendo-pulse 0.95s linear infinite;
  }
  @keyframes crescendo-pulse { to { transform: rotate(360deg); } }
  .crescendo-demo__skeleton-label {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: #b8c1d6;
  }
  .crescendo-demo__skeleton-sub {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: #7a85a3;
  }

  .crescendo-demo figcaption {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin-top: 0.75rem;
    padding: 0 0.25rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.8125rem;
    color: rgb(110, 110, 120);
  }
  .crescendo-demo figcaption a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    transition: color 0.15s;
    white-space: nowrap;
  }
  .crescendo-demo figcaption a:hover {
    color: #8b7cf0;
  }
  @media (max-width: 640px) {
    .crescendo-demo figcaption { flex-direction: column; align-items: flex-start; gap: 6px; }
  }
</style>
