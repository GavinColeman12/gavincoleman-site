---
export interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
}

const {
  title,
  description = "Independent technology consultant helping small and medium-sized businesses harness AI, automation, and modern software to grow faster and work smarter.",
  canonicalPath,
} = Astro.props;

const SITE = "https://crescendo-consulting.net";

// Structured data (JSON-LD), lets Google + AI answer engines identify,
// understand, and cite Crescendo as an entity. Site-wide org/person/website graph.
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ProfessionalService",
      "@id": `${SITE}/#org`,
      name: "Crescendo Consulting",
      alternateName: "Crescendo Consultants",
      url: SITE,
      logo: `${SITE}/images/logo.png`,
      image: `${SITE}/images/og-card.png`,
      description:
        "Independent AI & technology consulting. Fortune 100 AI playbooks delivered directly to your business, strategy through hands-on implementation, no agency overhead.",
      email: "gavin.coleman@crescendo-consulting.net",
      telephone: "+1-804-405-9880",
      priceRange: "$$$",
      areaServed: { "@type": "Country", name: "United States" },
      sameAs: [
        "https://www.linkedin.com/company/118973955/",
        "https://maps.google.com/?cid=2802388170733749468",
      ],
      founder: { "@id": `${SITE}/#gavin` },
      slogan: "Fortune 100 AI builds. Delivered directly to your business.",
      knowsAbout: [
        "Artificial intelligence",
        "Agentic AI",
        "Generative AI",
        "Machine learning",
        "Data engineering",
        "Intelligent automation",
        "AI strategy",
        "Digital transformation",
      ],
      serviceType: [
        "AI strategy consulting",
        "AI implementation & customization",
        "Data engineering & integration",
        "Managed AI operations",
      ],
    },
    {
      "@type": "Person",
      "@id": `${SITE}/#gavin`,
      name: "Gavin Coleman",
      jobTitle: "Independent AI & Technology Consultant",
      worksFor: { "@id": `${SITE}/#org` },
      url: SITE,
      email: "gavin.coleman@crescendo-consulting.net",
    },
    {
      "@type": "WebSite",
      "@id": `${SITE}/#website`,
      name: "Crescendo Consulting",
      url: SITE,
      publisher: { "@id": `${SITE}/#org` },
      inLanguage: "en-US",
    },
  ],
};

import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Google Tag Manager (container GTM-NQKQR4C2). Guarded to the production
       domain so localhost dev + Netlify deploy-previews don't fire tags. -->
  <script is:inline>
    (function () {
      if (!location.hostname.endsWith('crescendo-consulting.net')) return;
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-NQKQR4C2');
    })();
  </script>
  <!-- End Google Tag Manager -->

  <!-- Google Analytics 4 (gtag.js). Guarded to the production domain so
       localhost dev + Netlify deploy-previews don't pollute the data. -->
  <script is:inline>
    (function () {
      if (!location.hostname.endsWith('crescendo-consulting.net')) return;
      var GA_ID = 'G-ZZ9FFQWKTT';
      var s = document.createElement('script');
      s.async = true;
      s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
      document.head.appendChild(s);
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      window.gtag = gtag;
      gtag('js', new Date());
      gtag('config', GA_ID);
    })();
  </script>

  <title>{title}</title>
  <meta name="description" content={description} />
  {canonicalPath && <link rel="canonical" href={`https://crescendo-consulting.net${canonicalPath}`} />}

  <!-- Favicons + app icon — the exact Crescendo chevron mark. SVG first so
       Chrome/Firefox use the crisp scalable logo; .ico/.png are fallbacks. -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="256x256" href="/favicon.png" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <!-- Open Graph + Twitter card meta -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Crescendo Consulting" />
  <meta property="og:url" content={canonicalPath ? `${SITE}${canonicalPath}` : SITE} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${SITE}/images/og-card.png`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Crescendo Consulting, Fortune 100 AI builds, delivered directly to your business" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${SITE}/images/og-card.png`} />

  <!-- Structured data (JSON-LD), entity graph for Google + AI answer engines -->
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fraunces:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- Cal.com embed script -->
  <script is:inline>
    (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
    Cal("init", "intro", {origin:"https://app.cal.com"});
    Cal.ns.intro("ui", {"hideEventTypeDetails":false,"layout":"week_view"});
  </script>
</head>
<body>

  <!-- Google Tag Manager (noscript), fallback for JS-disabled browsers -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NQKQR4C2"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->

  <!-- Scroll progress bar, top of viewport -->
  <div class="scroll-progress" aria-hidden="true"></div>

  <!-- NAV -->
  <nav class="nav">
    <div class="nav__inner">
      <a href="/" class="nav__brand" aria-label="Crescendo Consultants, home">
        <img src="/images/logo-chevron.png" alt="" class="nav__brand-chevron" aria-hidden="true" />
        <span class="nav__brand-wordmark-wrap">
          <img src="/images/logo-wordmark.png" alt="Crescendo Consultants" class="nav__brand-wordmark" />
        </span>
      </a>
      <ul class="nav__links">
        <li><a href="/#about">About</a></li>
        <li><a href="/#services">Services</a></li>
        <li><a href="/insights">Insights</a></li>
        <li><a href="/#case-studies">Case Studies</a></li>
        <li><a href="/faq">FAQ</a></li>
        <li>
          <a href="/sonar/demo" class="nav__link--live">
            <span class="nav__live-dot" aria-hidden="true"></span>
            Live Demos
          </a>
        </li>
      </ul>
      <a href="/#contact" class="btn btn--primary btn--small nav__cta" data-cal-link="gavin-coleman-pxrlkg/intro" data-cal-namespace="intro" data-cal-config='{"layout":"week_view","useSlotsViewOnSmallScreen":"true"}'>Book a Call</a>

      <!-- Mobile hamburger toggle (visible only on small screens) -->
      <button class="nav__toggle" id="nav-toggle" aria-label="Open menu" aria-controls="nav-mobile" aria-expanded="false">
        <span class="nav__toggle-line"></span>
        <span class="nav__toggle-line"></span>
        <span class="nav__toggle-line"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile nav drawer -->
  <div class="nav-mobile" id="nav-mobile" hidden>
    <ul class="nav-mobile__links">
      <li>
        <a href="/sonar/demo" class="nav-mobile__link--live">
          <span class="nav__live-dot" aria-hidden="true"></span>
          Live Demo
        </a>
      </li>
      <li><a href="/#about">About</a></li>
      <li><a href="/#platform">The Platform</a></li>
      <li><a href="/#services">Services</a></li>
      <li><a href="/insights">Insights</a></li>
      <li><a href="/#case-studies">Case Studies</a></li>
      <li><a href="/faq">FAQ</a></li>
    </ul>
    <a href="/#contact" class="btn btn--primary btn--large nav-mobile__cta" data-cal-link="gavin-coleman-pxrlkg/intro" data-cal-namespace="intro" data-cal-config='{"layout":"week_view","useSlotsViewOnSmallScreen":"true"}'>Book a Call</a>
  </div>

  <slot />

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer__inner">
      <div class="footer__brand">
        <img src="/images/logo-light.png" alt="Crescendo Consultants" class="footer__logo" />
        <div>
          <div class="footer__name">Gavin Coleman</div>
          <div class="footer__tagline">Independent Technology Consultant</div>
        </div>
      </div>
      <div class="footer__links">
        <a href="/#about">About</a>
        <a href="/#services">Services</a>
        <a href="/insights">Insights</a>
        <a href="/demos">Demos</a>
        <a href="/#case-studies">Case Studies</a>
        <a href="/faq">FAQ</a>
        <a href="/#contact">Contact</a>
      </div>
      <div class="footer__contact">
        <a href="mailto:gavin.coleman@crescendo-consulting.net">gavin.coleman@crescendo-consulting.net</a>
        <span class="footer__sep">·</span>
        <a href="tel:+18044059880">+1 (804) 405-9880</a>
      </div>
      <div class="footer__copy">© 2026 Crescendo Consultants. All rights reserved.</div>
    </div>
  </footer>

  <script src="/script.js" is:inline></script>

  <!-- Lead capture popup -->
  <div id="lead-popup-overlay" style="display:none;">
    <div id="lead-popup">
      <button id="lead-popup-close" aria-label="Close">&times;</button>

      <div class="lead-popup-header">
        <img src="/images/logo.png" alt="Crescendo Consultants" class="lead-popup-logo" />
        <h2>Ready to Grow? Let's Connect.</h2>
        <p class="lead-popup-subtitle">Start with a free consultation</p>
        <p class="lead-popup-description">
          Tell me a bit about your business and goals. I'll follow up with personalized insights on how Crescendo Consultants can help you grow smarter.
        </p>
      </div>

      <form name="lead-capture" method="POST" data-netlify="true" netlify-honeypot="bot-field" id="lead-form">
        <input type="hidden" name="form-name" value="lead-capture" />
        <p style="display:none;">
          <label>Don't fill this out: <input name="bot-field" /></label>
        </p>

        <div class="form-row">
          <input type="text" name="name" placeholder="Name" required />
          <input type="email" name="email" placeholder="Email" required />
        </div>

        <input type="tel" name="phone" placeholder="Phone Number" />

        <textarea name="message" placeholder="Need help with strategy, growth, or AI implementation? Let me know where I can support you..." rows="4"></textarea>

        <button type="submit" class="lead-submit-btn">Let's Grow</button>
      </form>

      <div class="lead-popup-divider">
        <span>or</span>
      </div>
      <button class="lead-cal-btn" data-cal-link="gavin-coleman-pxrlkg/intro" data-cal-namespace="intro" data-cal-config='{"layout":"week_view","useSlotsViewOnSmallScreen":"true"}'>
        📅 Book a Free Intro Call
      </button>

      <div id="lead-success" style="display:none;">
        <h3>Thanks, I'll be in touch within 24 hours.</h3>
      </div>
    </div>
  </div>

  <!-- Hidden forms for Netlify form detection during build -->
  <form name="lead-capture" netlify netlify-honeypot="bot-field" hidden>
    <input type="text" name="name" />
    <input type="email" name="email" />
    <input type="tel" name="phone" />
    <textarea name="message"></textarea>
  </form>
  <form name="insights-signup" netlify netlify-honeypot="bot-field" hidden>
    <input type="email" name="email" />
  </form>

  <!-- Mobile nav toggle -->
  <script is:inline>
    (function() {
      const toggle = document.getElementById('nav-toggle');
      const drawer = document.getElementById('nav-mobile');
      if (!toggle || !drawer) return;

      function setOpen(open) {
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        toggle.classList.toggle('is-open', open);
        drawer.classList.toggle('is-open', open);
        document.body.classList.toggle('is-modal-open', open);
        if (open) {
          drawer.hidden = false;
          document.body.style.overflow = 'hidden';
        } else {
          document.body.style.overflow = '';
          // Allow transition to play, then re-hide for a11y
          setTimeout(function () {
            if (!drawer.classList.contains('is-open')) drawer.hidden = true;
          }, 300);
        }
      }

      // Click the scrim to close
      document.addEventListener('click', function (e) {
        if (e.target === document.body && document.body.classList.contains('is-modal-open')) {
          setOpen(false);
        }
      });

      toggle.addEventListener('click', function () {
        const isOpen = toggle.getAttribute('aria-expanded') === 'true';
        setOpen(!isOpen);
      });

      // Close when any link in the drawer is tapped
      drawer.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', function () { setOpen(false); });
      });

      // Close on Escape
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') setOpen(false);
      });
    })();

    // Nav brand demo, on first page load, autoplay the chevron→wordmark
    // hover reveal so users discover the interaction exists. Tease + collapse.
    (function () {
      var brand = document.querySelector('.nav__brand');
      if (!brand) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      // Skip on touch (wordmark is always shown there anyway)
      if (window.matchMedia('(hover: none)').matches) return;

      // After hero entrance settles, play the tease
      setTimeout(function () { brand.classList.add('nav__brand--demo'); }, 1400);
      // Hold the open state, then collapse back to chevron-only
      setTimeout(function () { brand.classList.remove('nav__brand--demo'); }, 4400);
    })();
  </script>

  <script is:inline>
    (function() {
      const POPUP_DELAY = 45000;
      const STORAGE_KEY = 'lead_popup_shown';

      function hasBeenShown() {
        return sessionStorage.getItem(STORAGE_KEY) === 'true';
      }
      function markAsShown() {
        sessionStorage.setItem(STORAGE_KEY, 'true');
      }
      function showPopup() {
        if (hasBeenShown()) return;
        const el = document.getElementById('lead-popup-overlay');
        if (el) { el.style.display = 'flex'; markAsShown(); }
      }
      function hidePopup() {
        const el = document.getElementById('lead-popup-overlay');
        if (el) el.style.display = 'none';
      }

      setTimeout(showPopup, POPUP_DELAY);

      const closeBtn = document.getElementById('lead-popup-close');
      if (closeBtn) closeBtn.addEventListener('click', hidePopup);

      const overlay = document.getElementById('lead-popup-overlay');
      if (overlay) overlay.addEventListener('click', function(e) {
        if (e.target.id === 'lead-popup-overlay') hidePopup();
      });

      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') hidePopup();
      });

      const form = document.getElementById('lead-form');
      if (form) form.addEventListener('submit', function(e) {
        e.preventDefault();
        const f = e.target;
        const data = new FormData(f);
        fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(data).toString()
        })
        .then(() => {
          f.style.display = 'none';
          const s = document.getElementById('lead-success');
          if (s) s.style.display = 'block';
          setTimeout(hidePopup, 3000);
        })
        .catch(() => {
          alert('There was an error submitting the form. Please try emailing gavin.coleman@crescendo-consulting.net directly.');
        });
      });
    })();
  </script>
</body>
</html>
