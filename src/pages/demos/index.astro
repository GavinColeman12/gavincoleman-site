---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DemosSection from '../../components/DemosSection.astro';
import ArrowTrack from '../../components/ArrowTrack.astro';
---

<BaseLayout
  title="Live Demos, Crescendo AI Strategy Consultants"
  description="Interactive, working demos of the AI tools Crescendo AI Strategy Consultants builds. Every demo runs live in your browser, no signup, no download, no sales call required."
  canonicalPath="/demos"
>
  <DemosSection compact={false} />

  <section class="demos-page-cta">
    <div class="demos-page-cta__inner">
      <h2 class="demos-page-cta__title">Seen one you want?</h2>
      <p class="demos-page-cta__dek">
        Book a 30-minute intro call. We'll tell you honestly whether the approach fits, and if it does, roughly what a build would cost and take.
      </p>
      <div class="demos-page-cta__actions">
        <a class="btn btn--primary btn--large" data-cal-link="gavin-coleman-pxrlkg/intro" data-cal-namespace="intro" data-cal-config='{"layout":"week_view","useSlotsViewOnSmallScreen":"true"}'>Book an Intro Call →</a>
        <a href="/faq" class="btn btn--ghost btn--large">Read the FAQ<ArrowTrack /></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .demos-page-cta {
    background: #fafaf7;
    padding: 0 24px 100px;
  }
  .demos-page-cta__inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 56px 32px;
    background: #fff;
    border: 1px solid #e0ddd4;
    border-radius: 14px;
    text-align: center;
  }
  .demos-page-cta__title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 32px;
    font-weight: 500;
    letter-spacing: -0.015em;
    color: #0a0e27;
    margin: 0 0 12px;
  }
  .demos-page-cta__dek {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 17px;
    line-height: 1.55;
    color: #3a3f54;
    margin: 0 0 28px;
  }
  .demos-page-cta__actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  @media (max-width: 600px) {
    .demos-page-cta { padding: 0 20px 80px; }
    .demos-page-cta__inner { padding: 40px 24px; }
  }
</style>
