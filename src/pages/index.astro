---
import BaseLayout from '../layouts/BaseLayout.astro';
import DemosSection from '../components/DemosSection.astro';
import ArrowTrack from '../components/ArrowTrack.astro';
---

<BaseLayout
  title="Crescendo Consultants — Independent AI & Technology Consulting"
  description="Fortune 100 AI playbooks delivered directly to your business. Independent strategy and implementation — no agency overhead."
  canonicalPath="/"
>

  <!-- HERO -->
  <header class="hero">
    <div class="hero__bg">
      <div class="hero__blob hero__blob--1"></div>
      <div class="hero__blob hero__blob--2"></div>
      <div class="hero__nebula hero__nebula--1"></div>
      <div class="hero__nebula hero__nebula--2"></div>
      <div class="hero__nebula hero__nebula--3"></div>
      <div class="hero__stars"></div>
      <div class="hero__noise"></div>
      <div class="hero__grid"></div>
      <canvas class="hero__canvas" aria-hidden="true"></canvas>
      <div class="hero__vignette"></div>
    </div>
    <div class="hero__inner">
      <div class="hero__copy">
        <div class="hero__eyebrow">
          <span class="hero__dot"></span>
          Available for new engagements
        </div>
        <h1 class="hero__title">
          Fortune 100 AI playbooks.<br/>
          <span class="hero__title-accent">Delivered directly to your business.</span>
        </h1>
        <p class="hero__subtitle">
          I've spent my career helping some of the world's biggest companies turn AI and data into measurable P&amp;L outcomes. Crescendo brings that same playbook to your team — senior work, directly delivered, no agency overhead.
        </p>
        <div class="hero__cta">
          <a href="#contact" class="btn btn--primary" data-cal-link="gavin-coleman-pxrlkg/intro" data-cal-namespace="intro" data-cal-config='{"layout":"week_view","useSlotsViewOnSmallScreen":"true"}'>Book a Free Intro Call →</a>
          <a href="#case-studies" class="btn btn--ghost">See Case Studies<ArrowTrack /></a>
        </div>
        <div class="hero__stats">
          <div class="stat">
            <div class="stat__value" data-count="8" data-suffix="+">8+</div>
            <div class="stat__label">Industries · Fortune 100 Engagements</div>
          </div>
          <div class="stat">
            <div class="stat__value">Bain · PS</div>
            <div class="stat__label">Pedigree · Independent Delivery</div>
          </div>
          <div class="stat">
            <div class="stat__value">Tailored, Not Templated</div>
            <div class="stat__label">Independent operator. Built for your business.</div>
          </div>
        </div>
      </div>
      <div class="hero__portrait">
        <div class="hero__portrait-frame">
          <img src="/images/hero-main.jpg" alt="Gavin Coleman presenting" />
        </div>
      </div>
    </div>
    <button
      class="hero__motion-toggle"
      type="button"
      aria-label="Pause background motion"
      aria-pressed="false"
    >
      <span class="hero__motion-toggle-icon" aria-hidden="true">
        <svg class="hero__motion-toggle-svg hero__motion-toggle-svg--pause" width="10" height="10" viewBox="0 0 10 10" fill="currentColor">
          <rect x="1.5" y="1" width="2.2" height="8" rx="0.6"/>
          <rect x="6.3" y="1" width="2.2" height="8" rx="0.6"/>
        </svg>
        <svg class="hero__motion-toggle-svg hero__motion-toggle-svg--play" width="10" height="10" viewBox="0 0 10 10" fill="currentColor">
          <path d="M2.2 1.3v7.4a0.4 0.4 0 0 0 0.62 0.34l5.4-3.7a0.4 0.4 0 0 0 0-0.68L2.82 0.96A0.4 0.4 0 0 0 2.2 1.3Z"/>
        </svg>
      </span>
      <span class="hero__motion-toggle-label">Pause motion</span>
    </button>
  </header>

  <!-- LOGO BAR -->
  <section class="logos">
    <p class="logos__label">Worked with teams at</p>
    <div class="logos__grid logos__grid--images">
      <div class="logos__item-img"><img src="/images/logos/disney.svg" alt="Disney" /></div>
      <div class="logos__item-img"><img src="/images/logos/marriott.svg" alt="Marriott" /></div>
      <div class="logos__item-img"><img src="/images/logos/walmart.svg" alt="Walmart" /></div>
      <div class="logos__item-img"><img src="/images/logos/dsg.svg" alt="Dick's Sporting Goods" /></div>
      <div class="logos__item-img"><img src="/images/logos/colgate.svg" alt="Colgate" /></div>
      <div class="logos__item-img"><img src="/images/logos/publicissapient.svg" alt="Publicis Sapient" /></div>
      <div class="logos__item-img"><img src="/images/logos/amex.svg" alt="American Express" /></div>
      <div class="logos__item-img"><img src="/images/logos/citi.svg" alt="Citi" /></div>
      <div class="logos__item-img"><img src="/images/logos/morganstanley.svg" alt="Morgan Stanley" /></div>
      <div class="logos__item-img"><img src="/images/logos/marcus.svg" alt="Marcus by Goldman Sachs" /></div>
      <div class="logos__item-img"><img src="/images/logos/fidelity.svg" alt="Fidelity" /></div>
      <div class="logos__item-img"><img src="/images/logos/santander.svg" alt="Santander" /></div>
      <div class="logos__item-img"><img src="/images/logos/bain.svg" alt="Bain &amp; Company" /></div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="about section">
    <div class="section__inner about__inner">
      <div class="about__photo">
        <div class="about__photo-frame">
          <img src="/images/about-portrait.jpg" alt="Gavin Coleman" />
        </div>
        <div class="about__photo-accent"></div>
      </div>
      <div class="about__content">
        <div class="eyebrow">About</div>
        <h2 class="section__title">
          Enterprise pattern recognition.<br/>
          Independent delivery.
        </h2>
        <p class="about__text">
          I started my career in high-stakes private equity, where I developed the analytical discipline and decision-making instincts that still shape how I approach every engagement. From there I moved into management consulting and eventually into a senior role leading Data &amp; AI strategy for enterprise clients. Across all three, the through-line has been the same: learning how capital allocators, operators, and technologists actually think — and translating between them.
        </p>
        <p class="about__text">
          I've led enterprise-scale AI and digital transformation programs across financial services, retail, hospitality, and entertainment — turning AI strategy into operational reality for Fortune 100 teams. My work spans the full arc: C-suite roadmaps and competitive assessments through hands-on implementation of agentic AI systems, data infrastructure, and intelligent automation.
        </p>
        <p class="about__text">
          I'm trained in both business strategy and modern technical execution — Python, SQL, cloud platforms, and the full agentic AI stack. I can present to the board in the morning and ship production code by that afternoon. That combination is rare, and it's why every engagement I take moves faster than a traditional consulting project.
        </p>
        <p class="about__text">
          Today I keep my client list deliberately small. When you hire Crescendo, you hire me — not a delivery team. That means you get the exact same thinking, the exact same code, from first call to final system. Here's how that works in practice:
        </p>
        <div class="about__highlights">
          <div class="highlight">
            <div class="highlight__icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </div>
            <div>
              <div class="highlight__title">Discovery &amp; Diagnosis</div>
              <div class="highlight__desc">I run a personal analysis of your business to surface the pain points and highest-ROI opportunities — before any build starts.</div>
            </div>
          </div>
          <div class="highlight">
            <div class="highlight__icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            </div>
            <div>
              <div class="highlight__title">Modern Methods &amp; Tools</div>
              <div class="highlight__desc">Agentic AI, Python, and cloud — the Fortune 100 stack, right-sized for your business.</div>
            </div>
          </div>
          <div class="highlight">
            <div class="highlight__icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
            <div>
              <div class="highlight__title">Working Systems, Not Slides</div>
              <div class="highlight__desc">Every engagement ships software your team actually runs. No decks on the shelf.</div>
            </div>
          </div>
          <div class="highlight">
            <div class="highlight__icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div>
              <div class="highlight__title">Direct Partnership</div>
              <div class="highlight__desc">You work with me — no handoffs, no junior analysts, no rotating faces.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- THE PLATFORM — Crescendo Digital Snapshot -->
  <section id="platform" class="platform section section--dark">
    <div class="section__inner">
      <div class="section__header">
        <div class="eyebrow eyebrow--light">The Platform</div>
        <h2 class="section__title section__title--light">
          Crescendo.<br/>
          <em>Continuous visibility across four pillars.</em>
        </h2>
        <p class="section__subtitle">
          Most small business owners are running blind. Thousands of dollars a month on marketing, social, SEO — and no clear answer to whether any of it is working. The Crescendo platform measures four pillars in one place — your reputation, your competitive position, your visibility across Google and AI search, and your technical foundation — and turns each gap into a dollar number you can act on.
        </p>
      </div>

      <div class="platform__inner">
        <div class="platform__video">
          <div class="platform__video-frame">
            <iframe
              src="https://www.loom.com/embed/97817dcbe5f949728349d9a321ee3f23"
              title="Crescendo Platform — 4-minute walkthrough"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen"
              allowfullscreen
            ></iframe>
          </div>
        </div>

        <div class="platform__copy">
          <ul class="platform__pillars">
            <li>
              <span class="platform__pillar-num">01</span>
              <div>
                <div class="platform__pillar-title">Reputation</div>
                <div class="platform__pillar-desc">Every Google, Yelp, and Reddit review read by Claude individually — surfaced as themes, complaints, and customer personas you've never seen sliced this way.</div>
              </div>
            </li>
            <li>
              <span class="platform__pillar-num">02</span>
              <div>
                <div class="platform__pillar-title">Competitive Benchmark</div>
                <div class="platform__pillar-desc">The three real competitors in your category, same neighborhood, scored on the same dimensions you are. Where they win. Where you do. The specific gap to close first.</div>
              </div>
            </li>
            <li>
              <span class="platform__pillar-num">03</span>
              <div>
                <div class="platform__pillar-title">AI Search Visibility</div>
                <div class="platform__pillar-desc">ChatGPT, Claude, Perplexity, Google AI Overview, and traditional Google asked the eleven questions your customers actually ask. Who they name, who they don't.</div>
              </div>
            </li>
            <li>
              <span class="platform__pillar-num">04</span>
              <div>
                <div class="platform__pillar-title">Technical Foundation</div>
                <div class="platform__pillar-desc">Page speed, structured data, on-page SEO, and security findings — each one named, scored by likelihood, and priced by what it costs you if it stays broken.</div>
              </div>
            </li>
            <li>
              <span class="platform__pillar-num">✶</span>
              <div>
                <div class="platform__pillar-title">Ask Anything, grounded</div>
                <div class="platform__pillar-desc">Query Claude on your actual business data once the audit runs. No generic answers — specific, sourced, actionable.</div>
              </div>
            </li>
          </ul>

          <div class="platform__sub">Monthly subscription · 3-month minimum · Free first Digital Snapshot</div>
          <div class="platform__actions">
            <a class="btn btn--primary btn--large" data-cal-link="gavin-coleman-pxrlkg/intro" data-cal-namespace="intro" data-cal-config='{"layout":"week_view","useSlotsViewOnSmallScreen":"true"}'>Get a free Digital Snapshot →</a>
            <a href="#contact" class="btn btn--ghost btn--large">Talk subscription<ArrowTrack /></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES — three engagement tiers -->
  <section id="services" class="services section section--dark">
    <div class="section__inner">
      <div class="section__header">
        <div class="eyebrow eyebrow--light">Services</div>
        <h2 class="section__title section__title--light">
          Three ways to work with Crescendo.
        </h2>
        <p class="section__subtitle">
          Every engagement is tailored, but the shape is consistent: start with a diagnostic, choose a build, stay on retainer if you want ongoing leadership. No RFPs, no SOW theater, no surprise invoices.
        </p>
      </div>

      <!-- TIER 1 — Diagnostic Sprint (50/50 copy + photo) -->
      <div class="tier tier--hero tier--with-image">
        <div class="tier__meta">
          <span class="tier__num">01</span>
          <span class="tier__label">Start here</span>
        </div>
        <div class="tier__hero-inner">
          <div class="tier__hero-copy">
            <h3 class="tier__title">The Two-Week Diagnostic Sprint</h3>
            <p class="tier__pitch">
              Before any build. Two weeks understanding your business, your data, and the bottlenecks actually costing you money. You leave with a written assessment, a ranked list of AI opportunities, and a concrete scope of work. The diagnostic fee credits toward whatever we build next.
            </p>
            <ul class="tier__bullets">
              <li>Full operational and data audit across your existing stack</li>
              <li>Prioritized list of AI opportunities, scored by ROI and effort</li>
              <li>Written scope of work for the top one or two opportunities</li>
              <li>An honest &quot;start here&quot; recommendation — or &quot;don&apos;t build this yet&quot;</li>
            </ul>
            <div class="tier__price-block tier__price-block--inline">
              <div class="tier__timeline">1–2 weeks · credits toward implementation</div>
            </div>
            <a class="btn btn--primary btn--large tier__cta" data-cal-link="gavin-coleman-pxrlkg/intro" data-cal-namespace="intro" data-cal-config='{"layout":"week_view","useSlotsViewOnSmallScreen":"true"}'>
              Book a Diagnostic Sprint →
            </a>
          </div>
          <div class="tier__hero-image">
            <img src="/images/services-whiteboard.jpg" alt="Gavin mapping engagement stages on a whiteboard" loading="lazy" />
          </div>
        </div>
      </div>

      <!-- TIER 2 — Implementation Builds -->
      <div class="tier tier--builds">
        <div class="tier__meta">
          <span class="tier__num">02</span>
          <span class="tier__label">Build with Crescendo</span>
        </div>
        <p class="tier__intro">
          Six build archetypes we ship. Each is a working system your team can run independently when we're done — not a slide deck. Most clients come in through the diagnostic and pick the build that maps to their priority opportunity.
        </p>
        <div class="builds__grid">
          <a href="/demos#demo-ai-intake-form" class="build-card">
            <div class="build-card__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </div>
            <h4 class="build-card__title">AI Intake &amp; Voice Capture</h4>
            <p class="build-card__desc">24/7 conversational intake forms and voice AI that book appointments, qualify leads, and route urgent calls — before your team even logs in.</p>
            <div class="build-card__meta">
              <span>2–4 weeks</span>
            </div>
            <span class="build-card__cta">See the demos<ArrowTrack /></span>
          </a>

          <a href="/demos#demo-reputation-intelligence" class="build-card">
            <div class="build-card__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l2.5 6.5L21 9l-5 4.5L17 21l-5-3-5 3 1-7.5L3 9l6.5-.5z"/></svg>
            </div>
            <h4 class="build-card__title">Reputation &amp; Review Intelligence</h4>
            <p class="build-card__desc">Ingest reviews across every platform, extract sentiment and themes, and draft responses at scale — in your voice, queued for approval in a 15-minute sitting.</p>
            <div class="build-card__meta">
              <span>2–4 weeks</span>
            </div>
            <span class="build-card__cta">See the demo<ArrowTrack /></span>
          </a>

          <a href="/demos#demo-geo-content-rewriter" class="build-card">
            <div class="build-card__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </div>
            <h4 class="build-card__title">GEO &amp; AI Search Optimization</h4>
            <p class="build-card__desc">Rewrite your website so it shows up in Google's AI Overviews, ChatGPT answers, and Perplexity citations. Most small-business sites are structurally invisible to AI search.</p>
            <div class="build-card__meta">
              <span>1 wk / 20 pages</span>
            </div>
            <span class="build-card__cta">See the demo<ArrowTrack /></span>
          </a>

          <a href="/demos#demo-hr-policy-chatbot" class="build-card">
            <div class="build-card__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            </div>
            <h4 class="build-card__title">Internal Knowledge &amp; HR Assistants</h4>
            <p class="build-card__desc">Employees get instant answers to handbook, benefits, and policy questions — with citations to the source doc. HR stops answering the same fifty things every week.</p>
            <div class="build-card__meta">
              <span>2–3 weeks</span>
            </div>
            <span class="build-card__cta">See the demo<ArrowTrack /></span>
          </a>

          <a href="/demos#demo-client-portfolio-dashboard" class="build-card">
            <div class="build-card__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            </div>
            <h4 class="build-card__title">Agentic Operational Workflows</h4>
            <p class="build-card__desc">Multi-step AI agents that span your systems — onboarding pipelines, client-health dashboards, operational diligence, back-office automation.</p>
            <div class="build-card__meta">
              <span>4–12 weeks</span>
            </div>
            <span class="build-card__cta">See the demo<ArrowTrack /></span>
          </a>

          <a href="#contact" class="build-card build-card--custom" data-cal-link="gavin-coleman-pxrlkg/intro" data-cal-namespace="intro" data-cal-config='{"layout":"week_view","useSlotsViewOnSmallScreen":"true"}'>
            <div class="build-card__icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            </div>
            <h4 class="build-card__title">Custom AI Tools</h4>
            <p class="build-card__desc">Bespoke AI for odd-shaped problems that don't fit a template. Start with a diagnostic, leave with a working system designed for your exact business logic.</p>
            <div class="build-card__meta">
              <span>3–8 weeks</span>
            </div>
            <span class="build-card__cta">Start with a diagnostic<ArrowTrack /></span>
          </a>
        </div>
      </div>

      <!-- TIER 3 — Fractional Leadership -->
      <div class="tier tier--retainer">
        <div class="tier__meta">
          <span class="tier__num">03</span>
          <span class="tier__label">Ongoing partnership</span>
        </div>
        <div class="tier__hero-inner">
          <div class="tier__hero-copy">
            <h3 class="tier__title">Fractional AI &amp; Technology Leadership</h3>
            <p class="tier__pitch">
              For clients who want ongoing strategic technology guidance without the cost of a full-time CTO or Head of AI. A senior operator on retainer — on call for decisions, architecture, vendor selection, and roadmap reviews. Most engagements start after a discrete build and extend into a multi-quarter partnership.
            </p>
            <ul class="tier__bullets">
              <li>Weekly 30-minute strategic check-in</li>
              <li>Architecture and vendor decision support</li>
              <li>Team hiring, interviewing, and coaching</li>
              <li>On-call access for urgent technical questions</li>
              <li>Quarterly roadmap review with founders or board</li>
            </ul>
          </div>
          <div class="tier__hero-side">
            <div class="tier__price-block">
              <div class="tier__timeline">3-month minimum · typically 6–12 months</div>
            </div>
            <a class="btn btn--primary btn--large tier__cta" data-cal-link="gavin-coleman-pxrlkg/intro" data-cal-namespace="intro" data-cal-config='{"layout":"week_view","useSlotsViewOnSmallScreen":"true"}'>
              Book a Call →
            </a>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- CASE STUDIES -->
  <section id="case-studies" class="cases section">
    <div class="section__inner">
      <div class="section__header section__header--center">
        <div class="eyebrow">Case Studies</div>
        <h2 class="section__title">Real clients. Real numbers. Real outcomes.</h2>
        <p class="section__subtitle">The Fortune 100 pattern library, applied to mid-market problems. Every case below is a real client, with real results.</p>
      </div>
      <div class="cases__grid">
        <article class="case-card">
          <div class="case-card__tag">Healthcare · Reputation</div>
          <h3 class="case-card__title">Reputation Intelligence for a Manhattan Dental Practice</h3>
          <p class="case-card__desc">Built a custom AI reputation audit system that pulls reviews across platforms, runs sentiment analysis, and generates actionable recommendations — turning weeks of manual work into a 90-second automated process.</p>
          <div class="case-card__metrics">
            <div class="metric"><div class="metric__value">+40%</div><div class="metric__label">5-star review rate</div></div>
            <div class="metric"><div class="metric__value">15 hrs</div><div class="metric__label">Saved per week</div></div>
            <div class="metric"><div class="metric__value">89</div><div class="metric__label">Health score (up from 62)</div></div>
          </div>
        </article>

        <article class="case-card">
          <div class="case-card__tag">SaaS · HR Tech</div>
          <h3 class="case-card__title">AI-Powered HR Policy Assistant</h3>
          <p class="case-card__desc">Deployed a Claude-powered internal chatbot that ingests employee handbooks and HR policies, then answers employee questions in natural language 24/7 with citations to the source policy.</p>
          <div class="case-card__metrics">
            <div class="metric"><div class="metric__value">80%</div><div class="metric__label">HR questions self-served</div></div>
            <div class="metric"><div class="metric__value">6 hrs</div><div class="metric__label">HR time recovered weekly</div></div>
            <div class="metric"><div class="metric__value">85</div><div class="metric__label">Employees served</div></div>
          </div>
        </article>

        <article class="case-card">
          <div class="case-card__tag">Private Equity · M&amp;A · Intelligent Automation</div>
